# NextAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
# Production: https://dont-forget-kappa.vercel.app (no trailing slash)
NEXTAUTH_URL=

# Anthropic
ANTHROPIC_API_KEY=

# OpenWeather
OPENWEATHER_KEY=

# Upstash Redis (push notification subscriptions)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@dont-forget.app

# Vercel cron auth for /api/notify
CRON_SECRET=

# Manual E2E push test: GET /api/test-notify?secret=dontforget2026
